<UserControl
    x:Class="MVS.Projects"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    mc:Ignorable="d"
    d:DesignHeight="1100"
    d:DesignWidth="1400">

    <UserControl.Resources>

        <Style
            x:Key="ProjectStatusColor"
            TargetType="Ellipse">
            <Style.Triggers>

                <DataTrigger
                    Binding="{Binding projectStatus}"
                    Value="OFF">
                    <Setter
                        Property="Fill"
                        Value="{StaticResource ColorBackgroundSeparator}" />
                </DataTrigger>

                <DataTrigger
                    Binding="{Binding projectStatus}"
                    Value="GREEN">
                    <Setter
                        Property="Fill"
                        Value="{StaticResource ColorGreen}" />
                </DataTrigger>

                <DataTrigger
                    Binding="{Binding projectStatus}"
                    Value="AMBER">
                    <Setter
                        Property="Fill"
                        Value="{StaticResource ColorAmber}" />
                </DataTrigger>

                <DataTrigger
                    Binding="{Binding projectStatus}"
                    Value="RED">
                    <Setter
                        Property="Fill"
                        Value="{StaticResource ColorRed}" />
                </DataTrigger>

            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition
                Height="50" />
            <RowDefinition
                Height="*" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="*" />
                <ColumnDefinition
                    Width="*" />
            </Grid.ColumnDefinitions>

            <!--Motion Data Set Controls-->
            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                Margin="8">

                <Button
                    Name="btnNew"
                    Click="btnNew_Click"
                    Width="110">New</Button>
                <Button
                    Name="btnDelete"
                    Click="btnDelete_Click"
                    Width="110"
                    Margin="8,0,0,0">Delete</Button>

            </StackPanel>

        </Grid>

        <Grid
            Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="8*" />
                <ColumnDefinition
                    Width="6*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition
                    Height="3*" />
                <RowDefinition
                    Height="*" />
            </Grid.RowDefinitions>

            <telerik:RadGridView
                Grid.Column="0"
                Name="gvProjects"
                Margin="8,0,0,8"
                ItemsSource="{Binding Project}"
                IsReadOnly="True"
                IsManipulationEnabled="True"
                CanUserSortColumns="True"
                ShowGroupPanel="False"
                CanUserReorderColumns="False"
                CanUserDeleteRows="True"
                RowIndicatorVisibility="Collapsed"
                SelectionMode="Single"
                AutoGenerateColumns="False"
                SelectionChanged="gvProjects_SelectionChanged">

                <telerik:RadGridView.Columns>
                    <telerik:GridViewDataColumn
                        Width="*"
                        Header="ID"
                        DataMemberBinding="{Binding Id}" />
                    <telerik:GridViewDataColumn
                        Width="3*"
                        Header="Name"
                        DataMemberBinding="{Binding Name}" />
                    <telerik:GridViewDataColumn
                        Width="2*"
                        Header="Date"
                        DataMemberBinding="{Binding DateString}" />
                    <!--<telerik:GridViewDataColumn
                        Width="*"
                        Header="Duration">
                    
                        <telerik:GridViewDataColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        Text="{Binding DurationString}" />
                                    <Ellipse
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        Style="{StaticResource ProjectStatusColor}" />
                                </StackPanel>
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellTemplate>
                        
                    </telerik:GridViewDataColumn>-->

                </telerik:RadGridView.Columns>

            </telerik:RadGridView>

            <ScrollViewer
                Grid.Column="1"
                Grid.Row="0"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                <telerik:GroupBox
                    Header="Project Details"
                    Margin="8">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="2*" />
                            <ColumnDefinition
                                Width="5*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="*"
                                MinHeight="28" />
                            <RowDefinition
                                Height="3*"
                                MinHeight="80" />
                        </Grid.RowDefinitions>

                        <!--ID-->
                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="ID"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="1"
                            Name="lbDataSetID"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Content="Name"
                            VerticalAlignment="Center" />

                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            FontSize="{StaticResource fontSizeProjectDetails}"
                            Name="tbDataSetName"
                            VerticalAlignment="Center"
                            LostFocus="tbDataSetName_LostFocus"
                            KeyDown="tbDataSetName_KeyDown" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            FontSize="{StaticResource fontSizeProjectDetails}"
                            IsHitTestVisible="False"
                            Text="Enter a name here"
                            Foreground="DarkGray"
                            VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style
                                    TargetType="{x:Type TextBlock}">
                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding Text, ElementName=tbDataSetName}"
                                            Value="">
                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <telerik:Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Content="Comments"
                            VerticalAlignment="Center" />

                        <TextBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Name="tbDataSetComments"
                            FontSize="{StaticResource fontSizeProjectDetails}"
                            VerticalAlignment="Center"
                            LostFocus="tbDataSetDescription_LostFocus"
                            KeyDown="tbDataSetDescription_KeyDown"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            FontSize="{StaticResource fontSizeProjectDetails}"
                            IsHitTestVisible="False"
                            Text="Enter comments here"
                            Foreground="DarkGray"
                            VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style
                                    TargetType="{x:Type TextBlock}">
                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding Text, ElementName=tbDataSetComments}"
                                            Value="">
                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <telerik:Label
                            Grid.Row="3"
                            Grid.Column="0"
                            Content="Input MRUs"
                            VerticalAlignment="Center" />

                        <telerik:RadComboBox
                            Grid.Row="3"
                            Grid.Column="1"
                            Name="cboInputMRUs"
                            VerticalAlignment="Center"
                            DropDownClosed="cboInputMRUs_DropDownClosed" />

                        <telerik:Label
                            Grid.Row="4"
                            Grid.Column="0"
                            Content="Date"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="4"
                            Grid.Column="1"
                            Name="lbDataSetDate"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="5"
                            Grid.Column="0"
                            Content="Start Time"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="5"
                            Grid.Column="1"
                            Name="lbDataSetStartTime"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="6"
                            Grid.Column="0"
                            Content="End Time"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="6"
                            Grid.Column="1"
                            Name="lbDataSetEndTime"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="7"
                            Grid.Column="0"
                            Content="Duration"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="7"
                            Grid.Column="1"
                            Name="lbDataSetDuration"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="8"
                            Grid.Column="0"
                            Name="lbImport"
                            Content="Import Test Data"
                            VerticalAlignment="Center" />

                        <Button
                            Grid.Row="8"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Name="btnImport"
                            Click="btnImport_Click"
                            Width="140">Import</Button>

                        <TextBlock
                            Grid.Row="9"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="8"
                            HorizontalAlignment="Left"
                            Name="tbDurationWarning"
                            Visibility="Collapsed"
                            Foreground="{StaticResource ColorRed}"
                            TextWrapping="Wrap"
                            Text="Warning: Data recording duration is to short. 20 minutes minimum. 40+ minutes is best."
                            VerticalAlignment="Center" />

                    </Grid>

                </telerik:GroupBox>

            </ScrollViewer>

            <Grid
                Grid.Column="0"
                Grid.Row="1"
                Grid.ColumnSpan="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="*" />
                </Grid.ColumnDefinitions>

                <telerik:GroupBox
                    Grid.Column="0"
                    Header="Pitch"
                    Margin="8">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition
                                Height="*" />
                            <RowDefinition
                                Height="*" />
                            <RowDefinition
                                Height="*" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--Pitch Title-->
                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="Reference"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="Test"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="3"
                            Content="Deviation"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Pitch Separator-->
                        <Separator
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            VerticalAlignment="Bottom" />

                        <!--Mean Pitch-->
                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Content="Mean"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="1"
                            Content="{Binding Path=refPitchMeanDataString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="{Binding Path=testPitchMeanDataString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Mean Pitch Deviation-->
                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="3"
                            Content="{Binding Path=devPitchMeanString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Pitch Correction-->
                        <Grid
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Background="{StaticResource ColorBackgroundSeparatorDark}">
                        </Grid>

                        <telerik:Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Content="Correction"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="2"
                            Grid.Column="3"
                            Content="{Binding Path=corrPitchString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                    </Grid>

                </telerik:GroupBox>

                <telerik:GroupBox
                    Grid.Column="1"
                    Header="Roll"
                    Margin="8">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition
                                Height="*" />
                            <RowDefinition
                                Height="*" />
                            <RowDefinition
                                Height="*" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--Roll Title-->
                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="Reference"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="Test"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="3"
                            Content="Deviation"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Roll Separator-->
                        <Separator
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            VerticalAlignment="Bottom" />

                        <!--Mean Roll-->
                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Content="Mean"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="1"
                            Content="{Binding Path=refRollMeanDataString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="{Binding Path=testRollMeanDataString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Mean Roll Deviation-->
                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="3"
                            Content="{Binding Path=devRollMeanString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Roll Correction-->
                        <Grid
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Background="{StaticResource ColorBackgroundSeparatorDark}">
                        </Grid>

                        <telerik:Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Content="Correction"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="2"
                            Grid.Column="3"
                            Content="{Binding Path=corrRollString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                    </Grid>

                </telerik:GroupBox>

                <telerik:GroupBox
                    Grid.Column="2"
                    Header="Heave"
                    Margin="8">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition
                                Height="*" />
                            <RowDefinition
                                Height="*" />
                            <RowDefinition
                                Height="*" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--Heave Title-->
                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="Reference"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="Test"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="0"
                            Grid.Column="3"
                            Content="Deviation"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Heave Separator-->
                        <Separator
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            VerticalAlignment="Bottom" />

                        <!--Mean Heave-->
                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Content="Mean"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="1"
                            Content="{Binding Path=refHeaveMeanString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="{Binding Path=testHeaveMeanString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Mean Heave Deviation-->
                        <telerik:Label
                            Grid.Row="1"
                            Grid.Column="3"
                            Content="{Binding Path=devHeaveMeanString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!--Heave Correction-->
                        <Grid
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Background="{StaticResource ColorBackgroundSeparatorDark}">
                        </Grid>

                        <telerik:Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Content="Correction"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

                        <telerik:Label
                            Grid.Row="2"
                            Grid.Column="3"
                            Content="{Binding Path=corrHeaveString}"
                            FontSize="{StaticResource fontSizeData}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                    </Grid>

                </telerik:GroupBox>
                
            </Grid>

        </Grid>

    </Grid>

</UserControl>
