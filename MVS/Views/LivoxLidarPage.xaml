 <UserControl
    x:Class="MVS.LivoxLidarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="900" d:DesignWidth="1400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500" />
            <ColumnDefinition Width="*" MinWidth="200" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════ Columns 0-1: Controls + Status -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Tabbed Controls -->
            <telerik:RadTabControl Name="tabControl" Margin="8,8,8,8">

                <!-- ═══════════════════ Setup Tab ═══════════════════ -->
                <telerik:RadTabItem Header="Setup">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8">

                            <!-- Connection -->
                            <telerik:GroupBox Header="Connection" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="SDK Config File" VerticalAlignment="Center"/>
                                        <TextBox Name="tbConfigFilePath"
                                                 Text="{Binding ConfigFilePath, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="Path to mid360_config.json" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="LiDAR IP" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="SDK Status" VerticalAlignment="Center"/>
                                        <Label Content="{Binding SdkStatus}" />
                                    </DockPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <telerik:RadButton Command="{Binding ConnectCommand}"
                                                           Width="100" Margin="0,0,8,0">Connect</telerik:RadButton>
                                        <telerik:RadButton Command="{Binding DisconnectCommand}"
                                                           Width="100">Disconnect</telerik:RadButton>
                                    </StackPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Helideck -->
                            <telerik:GroupBox Header="Helideck" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Helideck Shape" VerticalAlignment="Center"
                                               ToolTip="Shape of the helideck — used by the edge detection analysis to prioritise straight edges"/>
                                        <telerik:RadComboBox ItemsSource="{Binding HelideckShapeOptions}"
                                                             SelectedItem="{Binding HelideckShape}"
                                                             Width="150" HorizontalAlignment="Left" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Vessel Fwd Method" VerticalAlignment="Center"
                                               ToolTip="Automatic: use edge detection result. LidarForward: assume sensor +X is vessel forward (0°). Manual: user-specified angle."/>
                                        <telerik:RadComboBox ItemsSource="{Binding VesselForwardMethodOptions}"
                                                             SelectedItem="{Binding VesselFwdMethod}"
                                                             Width="150" HorizontalAlignment="Left" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,4"
                                               IsEnabled="{Binding IsManualVesselFwd}">
                                        <Label Width="150" Content="Manual Heading (°)" VerticalAlignment="Center"
                                               ToolTip="Vessel forward heading in degrees from sensor +X axis"/>
                                        <TextBox Text="{Binding VesselFwdManualDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Point Cloud Filters -->
                            <telerik:GroupBox Header="Point Cloud Filters" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Range Min (mm)" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding RangeMinMm, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Range Max (mm)" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding RangeMaxMm, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <Separator Margin="0,4,0,4"/>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Azimuth Min (°)" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding AzimuthMinDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Azimuth Max (°)" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding AzimuthMaxDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <Separator Margin="0,4,0,4"/>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Elevation Min (°)" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding ElevationMinDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Elevation Max (°)" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding ElevationMaxDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <Separator Margin="0,4,0,4"/>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Max Points" VerticalAlignment="Center"
                                               ToolTip="Maximum number of points to keep in the buffer. When exceeded, oldest points are replaced by newer ones."/>
                                        <TextBox Text="{Binding MaxBufferPoints, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Calculation Minimums -->
                            <telerik:GroupBox Header="Calculation Minimums" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Min Fit Points" VerticalAlignment="Center"
                                               ToolTip="Minimum number of inlier points required to run the plane fit. The fit is rejected and an error dialog is shown if the count is below this threshold."/>
                                        <TextBox Text="{Binding MinFitPoints, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Min Edge Points" VerticalAlignment="Center"
                                               ToolTip="Minimum number of edge-band points required to accept the deck-edge detection. Detection is rejected and an error dialog is shown if the count is below this threshold."/>
                                        <TextBox Text="{Binding MinEdgePoints, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </telerik:RadTabItem>

                <!-- Scan Tab -->
                <telerik:RadTabItem Header="Scan">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8">

                            <!-- Scan Control -->
                            <telerik:GroupBox Header="Scan Control" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,8">
                                        <Label Width="150" Content="Accumulated Points" VerticalAlignment="Center"/>
                                        <Label Content="{Binding AccumulatedPointsString}" FontWeight="Bold"/>
                                    </DockPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <telerik:RadButton Command="{Binding StartScanCommand}"
                                                           Width="110" Margin="0,0,8,0">Start Scan</telerik:RadButton>
                                        <telerik:RadButton Command="{Binding StopScanCommand}"
                                                           Width="110">Stop Scan</telerik:RadButton>
                                    </StackPanel>

                                    <telerik:RadButton Command="{Binding AnalyseCommand}"
                                                        HorizontalAlignment="Right"
                                                        Width="228" Margin="0,8,0,0"
                                                        ToolTip="Fit the deck plane and detect the bow edge">Analyse</telerik:RadButton>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Plane Fit -->
                            <telerik:GroupBox Header="Plane Fit" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Pitch" VerticalAlignment="Center"/>
                                        <Label Content="{Binding FitPitch}" FontWeight="Bold"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Roll" VerticalAlignment="Center"/>
                                        <Label Content="{Binding FitRoll}" FontWeight="Bold"/>
                                    </DockPanel>
                                    <Separator Margin="0,4,0,4"/>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Fit RMSE" VerticalAlignment="Center"/>
                                        <Label Content="{Binding FitRmse}"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Points used" VerticalAlignment="Center"/>
                                        <Label Content="{Binding FitPoints}"/>
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Vessel Forward -->
                            <telerik:GroupBox Header="Vessel Forward" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Edge Angle"
                                               ToolTip="Angle of the edge direction relative to the LiDAR forward axis in the deck plane"/>
                                        <Label Content="{Binding EdgeAngle}"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Edge Points" VerticalAlignment="Center"
                                               ToolTip="Number of deck-plane inlier points within the edge band (400 mm from the bow boundary), used for edge-line fitting and visualisation"/>
                                        <Label Content="{Binding EdgePointsStr}"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Detection Method" VerticalAlignment="Center"
                                               ToolTip="Which deck edge was used to infer the vessel forward direction (bow → aft → side edges)"/>
                                        <Label Content="{Binding EdgeMethod}" FontWeight="Bold"/>
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Resolved Forward"
                                               ToolTip="The vessel forward angle that will be used when applying correction"/>
                                        <Label Content="{Binding ResolvedVesselFwd}" FontWeight="Bold"/>
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Active Correction -->
                            <telerik:GroupBox Header="Active Correction (Reference MRU)" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Status" VerticalAlignment="Center"/>
                                        <Label Content="{Binding Correction.StatusString}" FontWeight="Bold"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Pitch Offset" VerticalAlignment="Center"/>
                                        <Label Content="{Binding Correction.PitchOffsetString}" FontWeight="Bold"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Roll Offset" VerticalAlignment="Center"/>
                                        <Label Content="{Binding Correction.RollOffsetString}" FontWeight="Bold"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Heading Offset" VerticalAlignment="Center"/>
                                        <Label Content="{Binding Correction.HeadingOffsetString}" FontWeight="Bold"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Fit RMSE" VerticalAlignment="Center"/>
                                        <Label Content="{Binding Correction.FitRmseString}"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <Label Width="150" Content="Applied" VerticalAlignment="Center"/>
                                        <Label Content="{Binding Correction.TimestampString}"/>
                                    </DockPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <telerik:RadButton Command="{Binding ApplyCorrectionCommand}"
                                                           Width="150" Margin="0,0,8,0"
                                                           ToolTip="Apply this fit as the Reference MRU correction">
                                            Apply Correction
                                        </telerik:RadButton>
                                        <telerik:RadButton Command="{Binding ClearCorrectionCommand}"
                                                           Width="150">
                                            Clear Correction
                                        </telerik:RadButton>
                                    </StackPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </telerik:RadTabItem>

                <!-- Simulation Tab -->
                <telerik:RadTabItem Header="Simulation">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8">

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="Gray" FontStyle="Italic"
                                       Text="Generate a synthetic helideck scan without hardware. Uses the same filter, fit and correction pipeline as a real scan." />

                            <!-- LiDAR Sensor Configuration -->
                            <telerik:GroupBox Header="LiDAR Sensor Configuration" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Height (m)" VerticalAlignment="Center"
                                               ToolTip="Height of the LiDAR sensor above the deck surface in meters (default: 0.8 m)"/>
                                        <TextBox Text="{Binding SimLidarHeightM, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Yaw (°)" VerticalAlignment="Center"
                                               ToolTip="Rotation of the LiDAR sensor relative to the deck heading (clockwise positive)"/>
                                        <TextBox Text="{Binding SimLidarYawDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Pitch (°)" VerticalAlignment="Center"
                                               ToolTip="LiDAR mounting pitch relative to deck (bow-up positive) - represents sensor misalignment"/>
                                        <TextBox Text="{Binding SimPitchDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Roll (°)" VerticalAlignment="Center"
                                               ToolTip="LiDAR mounting roll relative to deck (port-up positive) - represents sensor misalignment"/>
                                        <TextBox Text="{Binding SimRollDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Deck Inclination -->
                            <telerik:GroupBox Header="Deck Inclination" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Slant Type" VerticalAlignment="Center"
                                               ToolTip="Type of deck slant: Flat (single direction), Ridge (center high, slopes to two sides), CenterHigh (dome - slopes to all sides)"/>
                                        <telerik:RadComboBox ItemsSource="{Binding DeckSlantTypeOptions}"
                                                             SelectedItem="{Binding SimDeckSlantType}"
                                                             Width="150" HorizontalAlignment="Left" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Slant Angle (°)" VerticalAlignment="Center"
                                               ToolTip="Overall inclination angle of the deck in degrees (0° = level deck)"/>
                                        <TextBox Text="{Binding SimDeckSlantDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4"
                                               Visibility="{Binding IsFlatSlant, Converter={StaticResource BoolToVis}}">
                                        <Label Width="150" Content="Slant Direction (°)" VerticalAlignment="Center"
                                               ToolTip="Direction of the deck slant: 0° = bow-up, 90° = port-up, 180° = stern-up, 270° = starboard-up"/>
                                        <TextBox Text="{Binding SimDeckSlantDirDeg, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Effective Angles -->
                            <telerik:GroupBox Header="Effective Angles (LiDAR + Deck)" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Total Pitch (°)" VerticalAlignment="Center"
                                               ToolTip="Combined pitch from LiDAR mounting and deck inclination"/>
                                        <Label Content="{Binding EffectivePitchDeg, StringFormat={}{0:F3}°}" FontWeight="SemiBold"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Total Roll (°)" VerticalAlignment="Center"
                                               ToolTip="Combined roll from LiDAR mounting and deck inclination"/>
                                        <Label Content="{Binding EffectiveRollDeg, StringFormat={}{0:F3}°}" FontWeight="SemiBold"/>
                                    </DockPanel>
                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Point Cloud Settings -->
                            <telerik:GroupBox Header="Point Cloud Settings" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Noise (mm σ)" VerticalAlignment="Center"
                                               ToolTip="Gaussian noise standard deviation added to each simulated point"/>
                                        <TextBox Text="{Binding SimNoiseMm, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Points" VerticalAlignment="Center"
                                               ToolTip="Total number of points to generate in the simulation"/>
                                        <TextBox Text="{Binding SimPointCount, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>
                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Helideck Geometry -->
                            <telerik:GroupBox Header="Helideck Geometry" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Helideck Shape" VerticalAlignment="Center"
                                               ToolTip="Shape of the helideck boundary used in simulation"/>
                                        <telerik:RadComboBox ItemsSource="{Binding HelideckShapeOptions}"
                                                             SelectedItem="{Binding SimHelideckShape}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Show Cube 1" VerticalAlignment="Center"
                                               ToolTip="Include the large bow-side cube (2 m) in the simulation"/>
                                        <telerik:RadToggleSwitchButton IsChecked="{Binding SimShowCube1}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Show Cube 2" VerticalAlignment="Center"
                                               ToolTip="Include the small stern-side cube (0.5 m) in the simulation"/>
                                        <telerik:RadToggleSwitchButton IsChecked="{Binding SimShowCube2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </StackPanel>
                            </telerik:GroupBox>

                            <telerik:RadButton Command="{Binding SimulateScanCommand}"
                                               HorizontalAlignment="Right" Width="228">
                                Simulate Scan
                            </telerik:RadButton>

                        </StackPanel>
                    </ScrollViewer>
                </telerik:RadTabItem>

                <!-- 3D View Tab -->
                <telerik:RadTabItem Header="3D View">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8">

                            <!-- Display Filters -->
                            <telerik:GroupBox Header="Display Filters" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Max Display Points" VerticalAlignment="Center"
                                               ToolTip="Maximum number of points rendered in the 3D viewport (downsampled for performance)"/>
                                        <TextBox Text="{Binding MaxDisplayPoints, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Perspective View -->
                            <telerik:GroupBox Header="Perspective View" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Rotation X (°)" VerticalAlignment="Center"
                                               ToolTip="Vertical tilt angle for perspective view (default: -45)"/>
                                        <TextBox Text="{Binding PerspectiveRotX, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Rotation Y (°)" VerticalAlignment="Center"
                                               ToolTip="Horizontal rotation angle for perspective view (default: -45)"/>
                                        <TextBox Text="{Binding PerspectiveRotY, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Rotation Z (°)" VerticalAlignment="Center"
                                               ToolTip="Roll angle for perspective view (default: 0)"/>
                                        <TextBox Text="{Binding PerspectiveRotZ, UpdateSourceTrigger=LostFocus}" />
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <!-- Emissive Colors -->
                            <telerik:GroupBox Header="Colors" Margin="0,0,0,8">
                                <StackPanel Margin="8">

                                    <DockPanel Margin="0,0,0,4">
                                        <Label Width="150" Content="Enable Emissive" VerticalAlignment="Center"
                                               ToolTip="Enable emissive colors for point cloud rendering to make colors appear brighter and more vibrant"/>
                                        <telerik:RadToggleSwitchButton IsChecked="{Binding EnableEmissiveColors}" VerticalAlignment="Center"/>
                                    </DockPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </telerik:RadTabItem>

            </telerik:RadTabControl>

            </Grid>

            <!-- ═══════════════════════════════════════════════════ Column 2: 3D Viewport -->
        <Grid Grid.Column="1" Margin="4,8,8,8">

            <telerik:GroupBox Header="Point Cloud — 3D View">
                <Grid>

                    <!-- 3D Viewport wrapped in Border for full-area mouse hit-testing -->
                    <Border Background="Transparent"
                            MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                            MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                            MouseMove="Viewport_MouseMove"
                            MouseWheel="Viewport_MouseWheel">
                    <Viewport3D Name="viewport3D" ClipToBounds="True">

                        <Viewport3D.Camera>
                            <PerspectiveCamera x:Name="camera"
                                               Position="0,0,15000"
                                               LookDirection="0,0,-1"
                                               UpDirection="0,1,0"
                                               FieldOfView="45" />
                        </Viewport3D.Camera>

                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <Model3DGroup>
                                    <AmbientLight Color="#E0E0E0" />
                                    <DirectionalLight Color="#404040" Direction="0,0,-1" />
                                </Model3DGroup>
                            </ModelVisual3D.Content>
                        </ModelVisual3D>

                        <!-- Point cloud mesh — populated from code-behind -->
                        <ModelVisual3D x:Name="pointCloudVisual" />

                        <!-- Fitted plane mesh — populated from code-behind -->
                        <ModelVisual3D x:Name="planeVisual" />

                        <!-- Vessel forward direction arrow — populated from code-behind -->
                        <ModelVisual3D x:Name="forwardArrowVisual" />

                        <!-- Plane normal arrow — populated from code-behind -->
                        <ModelVisual3D x:Name="normalArrowVisual" />

                        <!-- LiDAR forward vector (purple) — populated from code-behind -->
                        <ModelVisual3D x:Name="lidarForwardArrowVisual" />

                    </Viewport3D>
                    </Border>

                    <!-- Scanning indicator -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,8,0,0" Padding="12,4" CornerRadius="4"
                            Background="#DD2E7D32"
                            Visibility="{Binding IsScanActive, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#88FF88" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.3" Duration="0:0:0.6"
                                                                 AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="SCANNING" FontSize="12" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Overlay hint -->
                    <TextBlock HorizontalAlignment="Left" VerticalAlignment="Bottom"
                               Margin="8" Opacity="1" FontSize="11"
                               Text="Drag to rotate  •  Scroll to zoom" />

                    <!-- 3D Axis Indicator - positioned above legend -->
                    <Border x:Name="axisIndicatorBorder" 
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="8,8,8,230" Padding="0" CornerRadius="4"
                            Background="#CCF0F0F0"
                            BorderBrush="#CCCCCC" BorderThickness="1"
                            Width="150" Height="180">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Viewport3D x:Name="axisViewport" Grid.Row="0" ClipToBounds="True">
                                <Viewport3D.Camera>
                                    <PerspectiveCamera x:Name="axisCamera"
                                                       Position="0,0,3000"
                                                       LookDirection="0,0,-1"
                                                       UpDirection="0,1,0"
                                                       FieldOfView="45" />
                                </Viewport3D.Camera>

                                <ModelVisual3D>
                                    <ModelVisual3D.Content>
                                        <Model3DGroup>
                                            <AmbientLight Color="#FFFFFF" />
                                        </Model3DGroup>
                                    </ModelVisual3D.Content>
                                </ModelVisual3D>

                                <!-- Axis arrows - populated from code-behind -->
                                <ModelVisual3D x:Name="axisXVisual" />
                                <ModelVisual3D x:Name="axisYVisual" />
                                <ModelVisual3D x:Name="axisZVisual" />
                            </Viewport3D>

                            <!-- Rotation readout -->
                            <Border Grid.Row="1" Background="#EEE8E8E8"
                                    BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"
                                    Padding="6,4">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="X " FontSize="13" Foreground="#CC2222"/>
                                        <TextBlock x:Name="tbRotX" FontSize="13" Foreground="#222222" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="Y " FontSize="13" Foreground="#007700"/>
                                        <TextBlock x:Name="tbRotY" FontSize="13" Foreground="#222222" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="Z " FontSize="13" Foreground="#003CB4"/>
                                        <TextBlock x:Name="tbRotZ" FontSize="13" Foreground="#222222" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Legend -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="8" Padding="10" CornerRadius="4"
                            Background="#CCF0F0F0"
                            BorderBrush="#CCCCCC" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Legend" FontWeight="Bold" FontSize="14"
                                       Foreground="#333333" Margin="0,0,0,6"/>

                            <!-- Heat-map bar -->
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock DockPanel.Dock="Left" Text="Low Z " FontSize="12" Foreground="#2255CC" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text=" High Z" FontSize="12" Foreground="#CC2222" VerticalAlignment="Center"/>
                                <Border Height="12" CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="Blue"   Offset="0.00"/>
                                            <GradientStop Color="Cyan"   Offset="0.25"/>
                                            <GradientStop Color="Lime"   Offset="0.50"/>
                                            <GradientStop Color="Yellow" Offset="0.75"/>
                                            <GradientStop Color="Red"    Offset="1.00"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </DockPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <Border Width="16" Height="16" Background="Red" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="LiDAR Forward (+X)" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <Border Width="16" Height="16" Background="#0078FF" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Plane Normal" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <Border Width="16" Height="16" Background="#FF8C00" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Bow Direction / Deck Edge" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <Border Width="16" Height="16" Background="#FF00FF" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Hex Vertices" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <Border Width="16" Height="16" Background="#50000000" CornerRadius="2" Margin="0,0,6,0"
                                        BorderBrush="#888" BorderThickness="1"/>
                                <TextBlock Text="Fitted Plane" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- View control buttons -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                                Orientation="Horizontal" Margin="8">
                        <telerik:RadButton Width="110" Opacity="0.8"
                                           Click="ResetCamera_Click"
                                           ToolTip="Reset camera to default top-down view"
                                           Margin="0,0,4,0">
                            Top View
                        </telerik:RadButton>
                        <telerik:RadButton Width="110" Opacity="0.8"
                                           Click="PerspectiveView_Click"
                                           ToolTip="View helideck from an angled 3D perspective">
                            Perspective View
                        </telerik:RadButton>
                    </StackPanel>

                </Grid>
            </telerik:GroupBox>

        </Grid>

        <!-- Analysis progress overlay -->
        <Border Grid.ColumnSpan="2"
                Background="#88000000"
                Visibility="{Binding IsAnalysing, Converter={StaticResource BoolToVis}}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#F0F5F5F5"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="8"
                    Padding="32,24"
                    MinWidth="320">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3" />
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <Grid Margin="0,0,0,16">
                        <telerik:RadProgressBar Minimum="0" Maximum="100"
                                                    Value="{Binding AnalyseProgress, Mode=OneWay}"
                                                    Width="260" Height="24"
                                                Foreground="#2E7D32" />
                        <TextBlock Text="{Binding AnalyseProgressText}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="12" FontWeight="Bold" Foreground="#222222" />
                    </Grid>
                    <TextBlock Text="Analysing point cloud…"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#222222"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding AnalyseStepText}"
                               FontSize="12"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Border>

    </Grid>

</UserControl>
