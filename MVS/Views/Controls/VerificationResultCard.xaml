<UserControl x:Class="MVS.Views.Controls.VerificationResultCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="380" d:DesignHeight="320">
    <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: axis title -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="tbAxisTitle"
                           Text="Axis"
                           FontSize="16"
                           FontWeight="Bold"/>
                <TextBlock x:Name="tbAxisUnit"
                           Grid.Column="1"
                           Text=""
                           Foreground="#57606A"
                           VerticalAlignment="Bottom"
                           Margin="6,0,0,2"/>
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="#E1E4E8" Margin="0,8"/>

            <!-- Stat columns: Reference / Test / Deviation -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Reference -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Reference" FontWeight="SemiBold" Foreground="#57606A"/>
                    <TextBlock x:Name="tbRefMean" Text="—" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                    <TextBlock x:Name="tbRefStdDev" Text="σ —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbRefMinMax" Text="min/max —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbRefRms" Text="RMS —" Foreground="#57606A" FontSize="11"/>
                </StackPanel>

                <!-- Test -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Test" FontWeight="SemiBold" Foreground="#57606A"/>
                    <TextBlock x:Name="tbTestMean" Text="—" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                    <TextBlock x:Name="tbTestStdDev" Text="σ —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbTestMinMax" Text="min/max —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbTestRms" Text="RMS —" Foreground="#57606A" FontSize="11"/>
                </StackPanel>

                <!-- Deviation -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Deviation" FontWeight="SemiBold" Foreground="#57606A"/>
                    <TextBlock x:Name="tbDevMean" Text="—" FontSize="20" FontWeight="Bold" Foreground="#0969DA" Margin="0,2,0,0"/>
                    <TextBlock x:Name="tbDevStdDev" Text="σ —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbDevOutliers" Text="outliers —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbDevSamples" Text="samples —" Foreground="#57606A" FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- Magnitude bar for deviation -->
            <telerik:RadProgressBar Grid.Row="3"
                                    x:Name="pbDeviationMagnitude"
                                    Height="4"
                                    Minimum="0" Maximum="100"
                                    Value="0"
                                    Margin="0,8,0,0"/>

            <!-- Footer: applied correction + actions -->
            <Grid Grid.Row="4" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Applied Correction" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbAppliedCorrection" Text="—" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadButton x:Name="btnCopy" Content="Copy"
                                       Click="btnCopy_Click"
                                       Margin="0,0,4,0" Padding="8,4"/>
                    <telerik:RadButton x:Name="btnApply" Content="Apply"
                                       Click="btnApply_Click"
                                       Margin="0,0,4,0" Padding="8,4"/>
                    <telerik:RadButton x:Name="btnReset" Content="Reset"
                                       Click="btnReset_Click"
                                       Padding="8,4"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
