<UserControl x:Class="MVS.Views.Controls.VerificationResultCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="380" d:DesignHeight="320">
    <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: axis title + acceptance status badge -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="tbAxisTitle"
                           Text="Axis"
                           FontSize="16"
                           FontWeight="Bold"/>
                <TextBlock x:Name="tbAxisUnit"
                           Grid.Column="1"
                           Text=""
                           Foreground="#57606A"
                           VerticalAlignment="Bottom"
                           Margin="6,0,0,2"/>
                <Border x:Name="statusBadge"
                        Grid.Column="3"
                        CornerRadius="10"
                        Padding="10,2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Background="#EFF2F5">
                    <TextBlock x:Name="tbStatusLabel"
                               Text="No data"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#57606A"/>
                </Border>
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="#E1E4E8" Margin="0,8"/>

            <!-- Stat columns: Reference / Test / Deviation / Correction -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Reference -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Reference MRU" FontWeight="SemiBold" Foreground="#57606A"/>
                    <TextBlock x:Name="tbRefMean" Text="—" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                    <TextBlock x:Name="tbRefStdDev" Text="σ —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbRefMinMax" Text="min/max —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbRefRms" Text="RMS —" Foreground="#57606A" FontSize="11"/>
                </StackPanel>

                <!-- Test -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Vessel MRU" FontWeight="SemiBold" Foreground="#57606A"/>
                    <TextBlock x:Name="tbTestMean" Text="—" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                    <TextBlock x:Name="tbTestStdDev" Text="σ —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbTestMinMax" Text="min/max —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbTestRms" Text="RMS —" Foreground="#57606A" FontSize="11"/>
                </StackPanel>

                <!-- Deviation -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Deviation" FontWeight="SemiBold" Foreground="#57606A"/>
                    <TextBlock x:Name="tbDevMean" Text="—" FontSize="20" FontWeight="Bold" Foreground="#0969DA" Margin="0,2,0,0"/>
                    <TextBlock x:Name="tbDevStdDev" Text="σ —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbDevOutliers" Text="outliers —" Foreground="#57606A" FontSize="11"/>
                    <TextBlock x:Name="tbDevSamples" Text="samples —" Foreground="#57606A" FontSize="11"/>
                </StackPanel>

                <!-- Correction -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Correction" FontWeight="SemiBold" Foreground="#57606A"/>
                    <TextBlock x:Name="tbCorrection" Text="—" FontSize="20" FontWeight="Bold" Foreground="#1A7F37" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Magnitude bar for deviation -->
            <telerik:RadProgressBar Grid.Row="3"
                                    x:Name="pbDeviationMagnitude"
                                    Height="4"
                                    Minimum="0" Maximum="100"
                                    Value="0"
                                    Margin="0,8,0,0"/>

            <!-- Plain-language assessment + glossary -->
            <Border Grid.Row="4"
                    x:Name="assessmentPanel"
                    CornerRadius="4"
                    BorderThickness="1"
                    Background="#EFF2F5"
                    BorderBrush="#D0D7DE"
                    Padding="8,6"
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="tbAssessment"
                               Text="Not enough captured data to assess this axis yet."
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#57606A"
                               VerticalAlignment="Center"/>
                    <telerik:RadButton x:Name="btnInfo"
                                       Grid.Column="1"
                                       Content="?"
                                       Width="24"
                                       Height="24"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Top"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#57606A"
                                       Background="#EFF2F5"
                                       BorderBrush="#D0D7DE"
                                       BorderThickness="1"
                                       CornerRadius="12"
                                       Padding="0"
                                       ToolTip="What do these numbers mean?"/>
                </Grid>
            </Border>


        </Grid>
    </Border>
</UserControl>
