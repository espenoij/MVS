<UserControl
    x:Class="MVS.Projects"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:controls="clr-namespace:MVS.Views.Controls"
    xmlns:local="clr-namespace:MVS"
    mc:Ignorable="d"
    d:DesignHeight="1100"
    d:DesignWidth="1400">

    <UserControl.Resources>

        <!-- Status indicator color for the project list "Status" column. -->
        <Style x:Key="ProjectStatusColor" TargetType="Ellipse">
            <Style.Triggers>
                <DataTrigger Binding="{Binding projectStatus}" Value="OFF">
                    <Setter Property="Fill" Value="{StaticResource ColorBackgroundSeparator}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding projectStatus}" Value="GREEN">
                    <Setter Property="Fill" Value="{StaticResource ColorGreen}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding projectStatus}" Value="AMBER">
                    <Setter Property="Fill" Value="{StaticResource ColorAmber}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding projectStatus}" Value="RED">
                    <Setter Property="Fill" Value="{StaticResource ColorRed}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

        <!-- Bridge element: DataContext is set to MainWindowVM in code-behind so Step 2 buttons can bind to it. -->
        <FrameworkElement x:Name="mainWindowVMBridge" Visibility="Collapsed"/>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Motion Unit Verification"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" — guided workflow"
                                   FontSize="14"
                                   Foreground="#57606A"
                                   VerticalAlignment="Center"
                                   Margin="6,2,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="tbWizardProjectName"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#0969DA"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>

                <!-- Step indicator -->
                <Border Grid.Row="1"
                        Background="#F6F8FA"
                        BorderBrush="#D0D7DE" BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,6"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="tbStep1" Text="1. Setup" FontWeight="Bold" Foreground="#0969DA"/>
                        <TextBlock Text="  ›  " Foreground="#57606A"/>
                        <TextBlock x:Name="tbStep2" Text="2. LiDAR" Foreground="#57606A"/>
                        <TextBlock Text="  ›  " Foreground="#57606A"/>
                        <TextBlock x:Name="tbStep3" Text="3. Capture" Foreground="#57606A"/>
                        <TextBlock Text="  ›  " Foreground="#57606A"/>
                        <TextBlock x:Name="tbStep4" Text="4. Review" Foreground="#57606A"/>
                        <TextBlock Text="  ›  " Foreground="#57606A"/>
                        <TextBlock x:Name="tbStep5" Text="5. Report" Foreground="#57606A"/>
                    </StackPanel>
                </Border>

                <!-- Body: requirements banner + the four step panels stacked, only one visible at a time -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Requirements banner: tells the user what is needed before they can proceed -->
                    <Border Grid.Row="0"
                            x:Name="requirementsBanner"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <TextBlock x:Name="tbRequirements"
                                   TextWrapping="Wrap"
                                   FontSize="12"/>
                    </Border>

                    <!-- Step panels -->
                    <Grid Grid.Row="1">

                    <!-- ===== STEP 1: SETUP ===== -->
                    <Grid x:Name="panelStep1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Projects list (left half of Step 1) -->
                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Projects"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <telerik:RadButton Name="btnNew"
                                                   Click="btnNew_Click"
                                                   Content="New"
                                                   Width="110"/>
                                <telerik:RadButton Name="btnDelete"
                                                   Click="btnDelete_Click"
                                                   Content="Delete"
                                                   Width="110"
                                                   Margin="8,0,0,0"/>
                            </StackPanel>

                            <telerik:RadGridView Grid.Row="2"
                                                 Name="gvProjects"
                                                 ItemsSource="{Binding Project}"
                                                 IsReadOnly="True"
                                                 IsManipulationEnabled="True"
                                                 CanUserSortColumns="True"
                                                 ShowGroupPanel="False"
                                                 CanUserReorderColumns="False"
                                                 CanUserDeleteRows="True"
                                                 RowIndicatorVisibility="Collapsed"
                                                 SelectionMode="Single"
                                                 AutoGenerateColumns="False"
                                                 SelectionChanged="gvProjects_SelectionChanged">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="40"
                                                                Header="ID"
                                                                DataMemberBinding="{Binding Id}" />
                                    <telerik:GridViewDataColumn Width="2*"
                                                                Header="Name"
                                                                DataMemberBinding="{Binding Name}" />
                                    <telerik:GridViewDataColumn Width="*"
                                                                Header="Date"
                                                                DataMemberBinding="{Binding DateString}" />
                                    <telerik:GridViewDataColumn Width="80" Header="Status">
                                        <telerik:GridViewDataColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <Ellipse Width="12" Height="12"
                                                             Style="{StaticResource ProjectStatusColor}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DataStatus}"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                        </Grid>

                        <!-- Project details (right half of Step 1) -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <TextBlock Text="Step 1 — Project setup"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#57606A"
                                           Margin="0,0,0,12"
                                           Text="Create or select a project, then describe the verification and pick the MRU input setup. The Test MRU is verified against the Reference MRU."/>

                                <telerik:GroupBox Header="Project Details" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="32"/>
                                            <RowDefinition Height="32"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="32"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" VerticalAlignment="Center" Foreground="#57606A"/>
                                        <Label Grid.Row="0" Grid.Column="1" Name="lbDataSetID" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" VerticalAlignment="Center" Foreground="#57606A"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Name="tbDataSetName"
                                                 VerticalContentAlignment="Center"
                                                 LostFocus="tbDataSetName_LostFocus"
                                                 KeyDown="tbDataSetName_KeyDown"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Comments" Margin="0,8,0,0" Foreground="#57606A"/>
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Name="tbDataSetComments"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Height="60"
                                                 Margin="0,4,0,0"
                                                 LostFocus="tbDataSetDescription_LostFocus"
                                                 KeyDown="tbDataSetDescription_KeyDown"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Input MRUs" VerticalAlignment="Center" Foreground="#57606A"/>
                                        <telerik:RadComboBox Grid.Row="3" Grid.Column="1"
                                                             Name="cboInputMRUs"
                                                             VerticalAlignment="Center"
                                                             DropDownClosed="cboInputMRUs_DropDownClosed"/>
                                    </Grid>
                                </telerik:GroupBox>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ===== STEP 2: LIDAR CORRECTION ===== -->
                    <Grid x:Name="panelStep2" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="Step 2 — LiDAR correction for Reference MRU"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,8"
                                       Text="Use the LiDAR scan to derive pitch/roll/heading offsets for the Reference MRU. Apply the correction before capturing motion data."/>
                        </StackPanel>

                        <local:LivoxLidarPage Grid.Row="1" x:Name="ucWizardLivoxLidarPage"/>
                    </Grid>

                    <!-- ===== STEP 3: CAPTURE ===== -->
                    <ScrollViewer x:Name="panelStep3" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="Step 3 — Capture motion data"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,12"
                                       Text="Record live motion data, or import an existing HMS recording for this project. The recommended verification window is 40 minutes."/>

                            <controls:DurationStatusBanner x:Name="durationBanner" Margin="0,0,0,12"/>

                            <telerik:GroupBox Header="Date / Duration" Margin="0,0,0,8">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Date"      Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="0" Grid.Column="1" Name="lbDataSetDate"      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Start"     Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="1" Grid.Column="1" Name="lbDataSetStartTime" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="End"       Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="2" Grid.Column="1" Name="lbDataSetEndTime"   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Duration"  Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="3" Grid.Column="1" Name="lbDataSetDuration"  VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                                               Name="tbDurationWarning"
                                               Text="Short recording — at least 20 minutes is recommended before analysis."
                                               Foreground="#9A6700"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </telerik:GroupBox>

                            <!-- Recording controls, bound to MainWindowVM via bridge element -->
                            <telerik:GroupBox Header="Recording" Margin="0,0,0,8">
                                <StackPanel Margin="8" Orientation="Vertical">

                                    <StackPanel Orientation="Horizontal">
                                        <telerik:RadButton x:Name="btnStartRecording"
                                                           Click="btnStartRecording_Click"
                                                           IsEnabled="{Binding DataContext.StartButtonEnabled, ElementName=mainWindowVMBridge}"
                                                           Content="Start Recording"
                                                           Width="160"
                                                           Margin="0,0,10,0"/>
                                        <telerik:RadButton x:Name="btnStopRecording"
                                                           Click="btnStopRecording_Click"
                                                           IsEnabled="{Binding DataContext.StopButtonEnabled, ElementName=mainWindowVMBridge}"
                                                           Content="Stop"
                                                           Width="120"
                                                           Margin="0,0,10,0"/>
                                        <telerik:RadButton x:Name="btnTestRun"
                                                           Click="btnTestRun_Click"
                                                           IsEnabled="{Binding DataContext.StartButtonEnabled, ElementName=mainWindowVMBridge}"
                                                           Content="Test Run"
                                                           Width="120"/>
                                    </StackPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <telerik:RadButton Name="btnImport"
                                                   Click="btnImport_Click"
                                                   Content="Import HMS data..."
                                                   Width="170"/>
                                <Label Name="lbImport"
                                       Content="Imports motion data from an existing HMS recording."
                                       Foreground="#57606A"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== STEP 4: REVIEW ===== -->
                    <ScrollViewer x:Name="panelStep4" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="Step 4 — Review per-axis results"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,12"
                                       Text="Inspect reference, test and deviation statistics for each axis. Use Apply to save the recommended correction for this project."/>

                            <controls:VerificationResultCard x:Name="cardPitch"
                                                             AxisTitle="Pitch"
                                                             Unit="°"
                                                             MagnitudeScale="1.0"
                                                             Margin="0,0,0,8"
                                                             CopyRequested="cardPitch_CopyRequested"
                                                             ApplyRequested="cardPitch_ApplyRequested"
                                                             ResetRequested="cardPitch_ResetRequested"/>

                            <controls:VerificationResultCard x:Name="cardRoll"
                                                             AxisTitle="Roll"
                                                             Unit="°"
                                                             MagnitudeScale="1.0"
                                                             Margin="0,0,0,8"
                                                             CopyRequested="cardRoll_CopyRequested"
                                                             ApplyRequested="cardRoll_ApplyRequested"
                                                             ResetRequested="cardRoll_ResetRequested"/>

                            <controls:VerificationResultCard x:Name="cardHeave"
                                                             AxisTitle="Heave"
                                                             Unit="m"
                                                             MagnitudeScale="0.5"
                                                             CopyRequested="cardHeave_CopyRequested"
                                                             ApplyRequested="cardHeave_ApplyRequested"
                                                             ResetRequested="cardHeave_ResetRequested"/>

                            <!-- Detailed data-analysis charts -->
                            <Expander x:Name="expDataAnalysis"
                                      Header="Detailed charts"
                                      IsExpanded="True"
                                      Margin="0,12,0,0">
                                <Border BorderBrush="#D0D7DE" BorderThickness="1"
                                        CornerRadius="4" Background="White"
                                        Margin="0,6,0,0">
                                    <local:DataAnalysis x:Name="ucDataAnalysis"
                                                        Height="1200"/>
                                </Border>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== STEP 5: APPLY & REPORT ===== -->
                    <ScrollViewer x:Name="panelStep5" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="Step 5 — Apply and report"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,12"
                                       Text="Export a verification report (CSV)."/>

                            <telerik:GroupBox Header="Applied Corrections" Margin="0,0,0,8">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Pitch correction"   Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="0" Grid.Column="1" x:Name="lbAppliedPitch"   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Roll correction"    Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="1" Grid.Column="1" x:Name="lbAppliedRoll"    VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Heave correction"   Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="2" Grid.Column="1" x:Name="lbAppliedHeave"   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Applied at (UTC)"   Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="3" Grid.Column="1" x:Name="lbAppliedAt"      VerticalAlignment="Center"/>
                                </Grid>
                            </telerik:GroupBox>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <telerik:RadButton x:Name="btnExportReport"
                                                   Click="btnExportReport_Click"
                                                   Content="Export report (CSV)..."
                                                   Width="190"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- Wizard navigation footer -->
                <Border Grid.Row="3"
                        BorderBrush="#D0D7DE" BorderThickness="0,1,0,0"
                        Padding="0,8,0,0" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="tbAnalysisStatus"
                                   VerticalAlignment="Center"
                                   Foreground="#57606A"
                                   Text=""/>

                        <telerik:RadButton Grid.Column="2"
                                           x:Name="btnPrev"
                                           Click="btnPrev_Click"
                                           Content="Back"
                                           Width="100"/>
                        <telerik:RadButton Grid.Column="3"
                                           x:Name="btnNext"
                                           Click="btnNext_Click"
                                           Content="Next"
                                           Width="100"
                                           Margin="8,0,0,0"/>
                    </Grid>
                </Border>
    </Grid>
</UserControl>
