<UserControl
    x:Class="MVS.Projects"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:controls="clr-namespace:MVS.Views.Controls"
    xmlns:local="clr-namespace:MVS"
    mc:Ignorable="d"
    d:DesignHeight="1100"
    d:DesignWidth="1400">

    <UserControl.Resources>

        <!-- Status indicator color for the project list "Status" column. -->
        <Style x:Key="ProjectStatusColor" TargetType="Ellipse">
            <Style.Triggers>
                <DataTrigger Binding="{Binding projectStatus}" Value="OFF">
                    <Setter Property="Fill" Value="{StaticResource ColorBackgroundSeparator}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding projectStatus}" Value="GREEN">
                    <Setter Property="Fill" Value="{StaticResource ColorGreen}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding projectStatus}" Value="AMBER">
                    <Setter Property="Fill" Value="{StaticResource ColorAmber}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding projectStatus}" Value="RED">
                    <Setter Property="Fill" Value="{StaticResource ColorRed}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

        <!-- Bridge element: DataContext is set to MainWindowVM in code-behind so Step 2 buttons can bind to it. -->
        <FrameworkElement x:Name="mainWindowVMBridge" Visibility="Collapsed"/>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Motion Unit Verification"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" — Guided workflow"
                                   FontSize="14"
                                   Foreground="#57606A"
                                   VerticalAlignment="Center"
                                   Margin="6,2,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="tbWizardProjectName"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#0969DA"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>

                <!-- Step indicator -->
                <Border Grid.Row="1"
                        Background="#F6F8FA"
                        BorderBrush="#D0D7DE" BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,6"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="tbStep1" Text="1. Setup" FontWeight="Bold" Foreground="#0969DA"/>
                            <TextBlock Text="  ›  " Foreground="#57606A"/>
                            <TextBlock x:Name="tbStep2" Text="2. LiDAR" Foreground="#57606A"/>
                            <TextBlock Text="  ›  " Foreground="#57606A"/>
                            <TextBlock x:Name="tbStep3" Text="3. Capture" Foreground="#57606A"/>
                            <TextBlock Text="  ›  " Foreground="#57606A"/>
                            <TextBlock x:Name="tbStep4" Text="4. Review" Foreground="#57606A"/>
                            <TextBlock Text="  ›  " Foreground="#57606A"/>
                            <TextBlock x:Name="tbStep5" Text="5. Report" Foreground="#57606A"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <telerik:RadButton x:Name="btnPrev"
                                             Click="btnPrev_Click"
                                             Content="Back"
                                             Width="100"/>
                            <telerik:RadButton x:Name="btnNext"
                                             Click="btnNext_Click"
                                             Content="Next"
                                             Width="100"
                                             Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Body: requirements banner + the four step panels stacked, only one visible at a time -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Requirements banner: tells the user what is needed before they can proceed -->
                    <Border Grid.Row="0"
                            x:Name="requirementsBanner"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <TextBlock x:Name="tbRequirements"
                                   TextWrapping="Wrap"
                                   FontSize="12"/>
                    </Border>

                    <!-- Step panels -->
                    <Grid Grid.Row="1">

                    <!-- ===== STEP 1: SETUP ===== -->
                    <Grid x:Name="panelStep1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Projects list (left half of Step 1) -->
                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Projects"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <telerik:RadButton Name="btnNew"
                                                   Click="btnNew_Click"
                                                   Content="New"
                                                   Width="110"/>
                                <telerik:RadButton Name="btnDelete"
                                                   Click="btnDelete_Click"
                                                   Content="Delete"
                                                   Width="110"
                                                   Margin="8,0,0,0"/>
                            </StackPanel>

                            <telerik:RadGridView Grid.Row="2"
                                                 Name="gvProjects"
                                                 ItemsSource="{Binding Project}"
                                                 IsReadOnly="True"
                                                 IsManipulationEnabled="True"
                                                 CanUserSortColumns="True"
                                                 ShowGroupPanel="False"
                                                 CanUserReorderColumns="False"
                                                 CanUserDeleteRows="True"
                                                 RowIndicatorVisibility="Collapsed"
                                                 SelectionMode="Single"
                                                 AutoGenerateColumns="False"
                                                 SelectionChanged="gvProjects_SelectionChanged">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="40"
                                                                Header="ID"
                                                                DataMemberBinding="{Binding Id}" />
                                    <telerik:GridViewDataColumn Width="2*"
                                                                Header="Name"
                                                                DataMemberBinding="{Binding Name}" />
                                    <telerik:GridViewDataColumn Width="*"
                                                                Header="Date"
                                                                DataMemberBinding="{Binding DateString}" />
                                    <telerik:GridViewDataColumn Width="80" Header="Status">
                                        <telerik:GridViewDataColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <Ellipse Width="12" Height="12"
                                                             Style="{StaticResource ProjectStatusColor}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DataStatus}"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                        </Grid>

                        <!-- Project details (right half of Step 1) -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <TextBlock Text="Step 1 — Project setup"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#57606A"
                                           Margin="0,0,0,12"
                                           Text="Create or select a project, then describe the verification and pick the MRU input setup. The Vessel MRU is verified against the Reference MRU."/>

                                <telerik:GroupBox Header="Project Details" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="32"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="32"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" VerticalAlignment="Center" Foreground="#57606A"/>
                                        <Label Grid.Row="0" Grid.Column="1" Name="lbDataSetID" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" VerticalAlignment="Top" Margin="0,8,0,0" Foreground="#57606A"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Name="tbDataSetName"
                                                 MinHeight="32"
                                                 TextWrapping="Wrap"
                                                 VerticalContentAlignment="Top"
                                                 Margin="0,4,0,0"
                                                 LostFocus="tbDataSetName_LostFocus"
                                                 KeyDown="tbDataSetName_KeyDown"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Input MRUs" VerticalAlignment="Center" Foreground="#57606A"/>
                                        <telerik:RadComboBox Grid.Row="2" Grid.Column="1"
                                                             Name="cboInputMRUs"
                                                             VerticalAlignment="Center"
                                                             DropDownClosed="cboInputMRUs_DropDownClosed"/>
                                    </Grid>
                                </telerik:GroupBox>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ===== STEP 2: LIDAR CORRECTION ===== -->
                    <Grid x:Name="panelStep2" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="Step 2 — LiDAR correction for Reference MRU"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,8"
                                       Text="1: Set up the LiDAR sensor. 2: Perform a scan. 3: Analyse the scan to derive pitch/roll/heading offsets. 4: Apply the correction to the Reference MRU before capturing motion data."/>
                        </StackPanel>

                        <local:LivoxLidarPage Grid.Row="1" x:Name="ucWizardLivoxLidarPage"/>
                    </Grid>

                    <!-- ===== STEP 3: CAPTURE ===== -->
                    <ScrollViewer x:Name="panelStep3" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="Step 3 — Capture motion data"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,12"
                                       Text="Record live motion data, or import an existing HMS recording for this project. The recommended verification window is 40 minutes."/>

                            <controls:DurationStatusBanner x:Name="durationBanner" Margin="0,0,0,12"/>

                            <telerik:GroupBox Header="Date / Duration" Margin="0,0,0,8">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Date"      Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="0" Grid.Column="1" Name="lbDataSetDate"      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Start"     Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="1" Grid.Column="1" Name="lbDataSetStartTime" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="End"       Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="2" Grid.Column="1" Name="lbDataSetEndTime"   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Duration"  Foreground="#57606A" VerticalAlignment="Center"/>
                                    <Label     Grid.Row="3" Grid.Column="1" Name="lbDataSetDuration"  VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                                               Name="tbDurationWarning"
                                               Text="Short recording — at least 20 minutes is recommended before analysis."
                                               Foreground="#9A6700"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </telerik:GroupBox>

                            <!-- Recording controls, bound to MainWindowVM via bridge element -->
                            <telerik:GroupBox Header="Recording" Margin="0,0,0,8">
                                <StackPanel Margin="8" Orientation="Vertical">

                                    <StackPanel Orientation="Horizontal">
                                        <telerik:RadButton x:Name="btnStartRecording"
                                                           Click="btnStartRecording_Click"
                                                           IsEnabled="{Binding DataContext.StartButtonEnabled, ElementName=mainWindowVMBridge}"
                                                           Content="Start Recording"
                                                           Width="160"
                                                           Margin="0,0,10,0"/>
                                        <telerik:RadButton x:Name="btnStopRecording"
                                                           Click="btnStopRecording_Click"
                                                           IsEnabled="{Binding DataContext.StopButtonEnabled, ElementName=mainWindowVMBridge}"
                                                           Content="Stop"
                                                           Width="120"
                                                           Margin="0,0,10,0"/>
                                        <telerik:RadButton x:Name="btnTestRun"
                                                           Click="btnTestRun_Click"
                                                           IsEnabled="{Binding DataContext.StartButtonEnabled, ElementName=mainWindowVMBridge}"
                                                           Content="Test Run"
                                                           Width="120"
                                                           Margin="0,0,10,0"/>
                                        <telerik:RadButton x:Name="btnClearRecording"
                                                           Click="btnClearRecording_Click"
                                                           Content="Clear Recording"
                                                           Width="160"
                                                           IsEnabled="False"/>
                                    </StackPanel>

                                </StackPanel>
                            </telerik:GroupBox>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <telerik:RadButton Name="btnImport"
                                                   Click="btnImport_Click"
                                                   Content="Import HMS data..."
                                                   Width="170"/>
                                <Label Name="lbImport"
                                       Content="Imports motion data from an existing HMS recording."
                                       Foreground="#57606A"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== STEP 4: REVIEW ===== -->
                    <ScrollViewer x:Name="panelStep4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Step 4 — Review per-axis results"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="1"
                                       TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,12"
                                       Text="Inspect reference, test and deviation statistics for each axis. The deviation is the value this tool calculates; each card instead grades the quality of the captured input data &#8212; samples, vessel motion and noise &#8212; to tell you whether that calculated deviation can be trusted. Press the ? button on a card for a full explanation. This page is for review only; use Apply to save the recommended correction for this project."/>

                            <controls:VerificationResultCard Grid.Row="2"
                                                             x:Name="cardPitch"
                                                             AxisTitle="Pitch"
                                                             Unit="°"
                                                             AxisKind="Pitch"
                                                             MagnitudeScale="1.0"
                                                             Margin="0,0,0,8"/>

                            <controls:VerificationResultCard Grid.Row="3"
                                                             x:Name="cardRoll"
                                                             AxisTitle="Roll"
                                                             Unit="°"
                                                             AxisKind="Roll"
                                                             MagnitudeScale="1.0"
                                                             Margin="0,0,0,8"/>

                            <controls:VerificationResultCard Grid.Row="4"
                                                             x:Name="cardHeave"
                                                             AxisTitle="Heave"
                                                             Unit="m"
                                                             AxisKind="Heave"
                                                             MagnitudeScale="0.5"/>

                            <!-- Detailed data-analysis charts -->
                            <Expander Grid.Row="5"
                                      x:Name="expDataAnalysis"
                                      Header="Detailed charts"
                                      IsExpanded="True"
                                      Margin="0,12,0,0">
                                <Border BorderBrush="#D0D7DE" BorderThickness="1"
                                        CornerRadius="4" Background="White"
                                        Margin="0,6,0,0">
                                    <local:DataAnalysis x:Name="ucDataAnalysis"
                                                        Height="1200"/>
                                </Border>
                            </Expander>

                        </Grid>
                    </ScrollViewer>

                    <!-- ===== STEP 5: APPLY & REPORT ===== -->
                    <Grid x:Name="panelStep5" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: project details + action buttons -->
                        <Grid Grid.Column="0" Margin="0,0,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Step 5 &#x2014; Apply and report"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="1"
                                       TextWrapping="Wrap"
                                       Foreground="#57606A"
                                       Margin="0,0,0,12"
                                       Text="Fill in all required fields (*), then click Generate Report. The report can be previewed on the right, saved as PDF, or opened directly."/>

                            <!-- Project details + report metadata for the report -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                              <StackPanel>
                            <telerik:GroupBox Header="Project Details" Margin="0,0,0,10">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Comments" Margin="0,0,0,4" VerticalAlignment="Top" Foreground="#57606A"/>
                                    <telerik:RadWatermarkTextBox Grid.Row="0" Grid.Column="1"
                                             Name="tbDataSetComments"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="60"
                                             Margin="0,0,0,6"
                                             WatermarkContent="Optional"
                                             LostFocus="tbDataSetDescription_LostFocus"
                                             KeyDown="tbDataSetDescription_KeyDown"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Operator *" VerticalAlignment="Center" Margin="0,4,0,0" Foreground="#57606A"/>
                                    <telerik:RadWatermarkTextBox Grid.Row="1" Grid.Column="1"
                                             Name="tbOperator"
                                             VerticalContentAlignment="Center"
                                             Margin="0,4,0,0"
                                             WatermarkContent="Required"
                                             LostFocus="tbOperator_LostFocus"
                                             KeyDown="tbOperator_KeyDown"
                                             TextChanged="tbReportField_TextChanged"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Vessel *" VerticalAlignment="Center" Margin="0,4,0,0" Foreground="#57606A"/>
                                    <telerik:RadWatermarkTextBox Grid.Row="2" Grid.Column="1"
                                             Name="tbVesselName"
                                             VerticalContentAlignment="Center"
                                             Margin="0,4,0,0"
                                             WatermarkContent="Required"
                                             LostFocus="tbVesselName_LostFocus"
                                             KeyDown="tbVesselName_KeyDown"
                                             TextChanged="tbReportField_TextChanged"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Location *" VerticalAlignment="Center" Margin="0,4,0,0" Foreground="#57606A"/>
                                    <telerik:RadWatermarkTextBox Grid.Row="3" Grid.Column="1"
                                             Name="tbLocation"
                                             VerticalContentAlignment="Center"
                                             Margin="0,4,0,0"
                                             WatermarkContent="Required"
                                             LostFocus="tbLocation_LostFocus"
                                             KeyDown="tbLocation_KeyDown"
                                             TextChanged="tbReportField_TextChanged"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Correction Applied" VerticalAlignment="Center" Margin="0,4,0,0" Foreground="#57606A"/>
                                    <CheckBox Grid.Row="4" Grid.Column="1"
                                              x:Name="chkCorrectionApplied"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="0,4,0,0"
                                              Checked="chkCorrectionApplied_Changed"
                                              Unchecked="chkCorrectionApplied_Changed"/>
                                </Grid>
                            </telerik:GroupBox>

                            <!-- Extended report metadata (equipment, setup, conditions, criteria, notes) -->
                            <telerik:GroupBox Header="Report Details" Margin="0,0,0,10">
                                <controls:ReportMetadataEditor x:Name="ucReportMetadata"
                                                               MetadataChanged="ucReportMetadata_MetadataChanged"
                                                               Margin="8"/>
                            </telerik:GroupBox>
                              </StackPanel>
                            </ScrollViewer>

                            <!-- Action buttons -->
                            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <telerik:RadButton x:Name="btnGenerateReport"
                                                       Click="btnGenerateReport_Click"
                                                       Content="Generate Report"
                                                       Width="170"/>
                                    <telerik:RadButton x:Name="btnUpdateReport"
                                                       Click="btnGenerateReport_Click"
                                                       Content="Update Report"
                                                       Visibility="Collapsed"
                                                       Width="170"
                                                       Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <telerik:RadButton x:Name="btnSaveReportToDisc"
                                                       Click="btnSaveReportToDisc_Click"
                                                       Content="Save Report"
                                                       IsEnabled="False"
                                                       Width="170"/>
                                    <telerik:RadButton x:Name="btnOpenPdfReport"
                                                       Click="btnOpenPdfReport_Click"
                                                       Content="Open PDF Report"
                                                       IsEnabled="False"
                                                       Width="170"
                                                       Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Right: report preview -->
                        <Border Grid.Column="1"
                                BorderBrush="#D0D7DE" BorderThickness="1"
                                CornerRadius="4" Background="#F6F8FA">
                            <Grid>
                                <TextBlock x:Name="tbReportPreviewEmpty"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#57606A"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Text="The report preview will appear here."/>
                                <telerik:RadPdfViewer x:Name="pdfReportPreview"
                                                      Visibility="Collapsed"
                                                      Background="#F6F8FA"/>
                            </Grid>
                        </Border>
                    </Grid>
                    </Grid>
                </Grid>

                <!-- Status footer -->
                <Border Grid.Row="3"
                        BorderBrush="#D0D7DE" BorderThickness="0,1,0,0"
                        Padding="0,8,0,0" Margin="0,8,0,0">
                    <TextBlock x:Name="tbAnalysisStatus"
                               VerticalAlignment="Center"
                               Foreground="#57606A"
                               Text=""/>
                </Border>
    </Grid>
</UserControl>
