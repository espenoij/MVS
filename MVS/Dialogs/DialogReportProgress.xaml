<telerik:RadWindow
    x:Class="MVS.DialogReportProgress"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:MVS"
    telerik:Header="Generating Report"
    WindowStartupLocation="CenterScreen"
    CanClose="False"
    Height="200"
    Width="500"
    telerik:StyleManager.Theme="Material">

    <telerik:RadWindow.Icon>
        <Image
            Height="32"
            Source="../Icons/mvs_windows_icon.ico" />
    </telerik:RadWindow.Icon>

    <telerik:RadWindow.Resources>
        <ResourceDictionary>
            <Style
                TargetType="local:DialogReportProgress"
                BasedOn="{StaticResource RadWindowStyle}" />
        </ResourceDictionary>
    </telerik:RadWindow.Resources>

    <StackPanel
        Margin="8">

        <telerik:Label
            x:Name="lblStatus"
            Content="Generating the verification report..." />

        <telerik:RadProgressBar
            Name="reportProgressBar"
            IsIndeterminate="True"
            Orientation="Horizontal"
            Height="30"
            Margin="0,8,0,0"
            Background="{StaticResource ColorBackgroundSeparatorDark}"
            Foreground="{StaticResource ColorGreen}" />

        <telerik:Label
            Content="This can take a moment for larger data sets."
            Foreground="#57606A"
            Margin="0,8,0,0" />

    </StackPanel>

</telerik:RadWindow>
