<telerik:RadWindow
    x:Class="MVS.DialogImport"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:MVS"
    telerik:Header="Import Test Data from HMS Database"
    WindowStartupLocation="CenterScreen"
    Height="440"
    Width="700"
    telerik:StyleManager.Theme="Material">

    <telerik:RadWindow.Icon>
        <Image
            Height="32"
            Source="../Icons/mvs_windows_icon.ico" />
    </telerik:RadWindow.Icon>

    <telerik:RadWindow.Resources>
        <ResourceDictionary>
            <Style
                TargetType="local:DialogImport"
                BasedOn="{StaticResource RadWindowStyle}" />
        </ResourceDictionary>
    </telerik:RadWindow.Resources>

    <DockPanel>

        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom">

            <Button
                Name="btnImport"
                Margin="8"
                Width="110"
                Content="Import"
                Click="btnImport_Click" />

        </StackPanel>

        <Grid
            DockPanel.Dock="Top">

            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="*" />
                <ColumnDefinition
                    Width="*" />
            </Grid.ColumnDefinitions>

            <!--PROJECT-->
            <telerik:GroupBox
                Grid.Column="0"
                Header="PROJECT"
                Margin="8">

                <Grid
                    Margin="8">

                    <Grid.RowDefinitions>
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                    </Grid.RowDefinitions>

                    <!--Name-->
                    <Grid
                        Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Name"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <telerik:Label
                            Grid.Column="1"
                            Name="tbDataSetName"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                    </Grid>

                    <!--Date-->
                    <Grid
                        Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Date"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <telerik:Label
                            Grid.Column="1"
                            Name="lbDataSetDate"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                    </Grid>

                    <!--Start Time-->
                    <Grid
                        Grid.Row="2">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Start Time"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <telerik:Label
                            Grid.Column="1"
                            Name="lbDataSetStartTime"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                    </Grid>

                    <!--End Time-->
                    <Grid
                        Grid.Row="3">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="End Time"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <telerik:Label
                            Grid.Column="1"
                            Name="lbDataSetEndTime"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                    </Grid>

                    <!--Duration-->
                    <Grid
                        Grid.Row="4">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Duration"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <telerik:Label
                            Grid.Column="1"
                            Name="lbDataSetDuration"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                    </Grid>

                </Grid>

            </telerik:GroupBox>

            <!--HMS DATABASE-->
            <telerik:GroupBox
                Grid.Column="1"
                Header="HMS DATABASE"
                Margin="8">

                <Grid
                    Margin="8">

                    <Grid.RowDefinitions>
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                        <RowDefinition
                            Height="*" />
                    </Grid.RowDefinitions>

                    <!--Address-->
                    <Grid
                        Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Address"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <TextBox
                            Grid.Column="1"
                            Width="110"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="{Binding Path=databaseAddress}"
                            LostFocus="tbSettingsHMSDatabaseAddress_LostFocus"
                            KeyDown="tbSettingsHMSDatabaseAddress_KeyDown" />
                    </Grid>

                    <!--Port-->
                    <Grid
                        Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Port"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <TextBox
                            Grid.Column="1"
                            Name="tbSettingsHMSDatabasePort"
                            Width="110"
                            HorizontalAlignment="Right"
                            HorizontalContentAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding Path=databasePort}"
                            LostFocus="tbSettingsHMSDatabasePort_LostFocus"
                            KeyDown="tbSettingsHMSDatabasePort_KeyDown" />
                    </Grid>

                    <!--Name-->
                    <Grid
                        Grid.Row="2">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Name"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <TextBox
                            Grid.Column="1"
                            Name="tbSettingsHMSDatabaseName"
                            Width="110"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="{Binding Path=databaseName}"
                            LostFocus="tbSettingsHMSDatabaseName_LostFocus"
                            KeyDown="tbSettingsHMSDatabaseName_KeyDown" />
                    </Grid>

                    <!--User ID-->
                    <Grid
                        Grid.Row="3">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="User ID"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <TextBox
                            Grid.Column="1"
                            Name="tbSettingsHMSDatabaseUserID"
                            Width="110"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            LostFocus="tbSettingsHMSDatabaseUserID_LostFocus"
                            KeyDown="tbSettingsHMSDatabaseUserID_KeyDown" />
                    </Grid>

                    <!--Password-->
                    <Grid
                        Grid.Row="4">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Password"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <TextBox
                            Grid.Column="1"
                            Name="tbSettingsHMSDatabasePassword"
                            Width="110"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            LostFocus="tbSettingsHMSDatabasePassword_LostFocus"
                            KeyDown="tbSettingsHMSDatabasePassword_KeyDown" />
                    </Grid>

                    <!--Table Name-->
                    <Grid
                        Grid.Row="5">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:Label
                            Grid.Column="0"
                            Content="Table Name"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />

                        <TextBox
                            Grid.Column="1"
                            Name="tbSettingsHMSDatabaseTableName"
                            Width="110"
                            Text="{Binding Path=databaseTableName}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            LostFocus="tbSettingsHMSDatabaseTableName_LostFocus"
                            KeyDown="tbSettingsHMSDatabaseTableName_KeyDown" />
                    </Grid>

                </Grid>

            </telerik:GroupBox>

        </Grid>

    </DockPanel>

</telerik:RadWindow>
